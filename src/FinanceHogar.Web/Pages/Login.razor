@page "/login"
@layout EmptyLayout
@inject AuthService AuthSvc
@inject NavigationManager Nav

<PageTitle>FinanceHogar — Acceso</PageTitle>

<div class="auth-wrapper">
    <div class="auth-orb2"></div>

    <div class="auth-card">

        @* Logo  *@
        <div class="text-center mb-4">
            <div class="mb-2">
                <i class="bi bi-house-heart-fill auth-logo-icon"></i>
            </div>
            <div class="auth-title">FinanceHogar</div>
            <div class="auth-subtitle mt-1">
                <span class="auth-online-dot me-1"></span>
                Sistema de control financiero familiar
            </div>
        </div>

        @* Tabs  *@
        <div class="auth-tabs mb-4">
            <button class="auth-tab @(_tab=="login"?"active":"")" @onclick='()=>{ _tab="login"; _error=""; }'>
                <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesión
            </button>
            <button class="auth-tab @(_tab=="register"?"active":"")" @onclick='()=>{ _tab="register"; _error=""; }'>
                <i class="bi bi-person-plus me-1"></i>Registrarse
            </button>
        </div>

        @* Error  *@
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="auth-error mb-3">
                <i class="bi bi-exclamation-triangle-fill"></i>
                @_error
            </div>
        }

        @if (_tab == "login")
        {
            @* Acceso rápido  *@
            <div class="mb-3">
                <div class="auth-quick-label mb-2">⚡ Acceso rápido (demo)</div>
                <div class="d-flex gap-2">
                    <button class="auth-quick-btn auth-quick-admin" @onclick="LoginAdmin" disabled="@_loading">
                        <i class="bi bi-shield-fill-check"></i>
                        <span>Admin</span>
                    </button>
                    <button class="auth-quick-btn auth-quick-user" @onclick="LoginUsuario" disabled="@_loading">
                        <i class="bi bi-person-fill"></i>
                        <span>Usuario</span>
                    </button>
                </div>
            </div>

            <div class="auth-divider mb-3">o ingresa tus credenciales</div>

            @* Correo  *@
            <div class="mb-3">
                <label class="auth-label">Correo electrónico</label>
                <div class="auth-input-group">
                    <i class="bi bi-envelope auth-input-icon"></i>
                    <input class="auth-input" type="email" @bind="_email" placeholder="correo@ejemplo.com" />
                </div>
            </div>

            @* Contraseña  *@
            <div class="mb-4">
                <label class="auth-label">Contraseña</label>
                <div class="auth-input-group">
                    <i class="bi bi-lock auth-input-icon"></i>
                    <input class="auth-input" type="password" @bind="_pass" placeholder="••••••••"
                           @onkeydown="@(async e => { if (e.Key == "Enter") await DoLogin(); })" />
                </div>
            </div>

            <button class="auth-btn-primary" @onclick="DoLogin" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Autenticando...</span>
                }
                else
                {
                    <i class="bi bi-box-arrow-in-right me-2"></i>
                    <span>Iniciar sesión</span>
                }
            </button>
        }
        else
        {
            <div class="mb-3">
                <label class="auth-label">Nombre completo *</label>
                <div class="auth-input-group">
                    <i class="bi bi-person auth-input-icon"></i>
                    <input class="auth-input" @bind="_regNombre" @bind:event="oninput" placeholder="Juan Pérez García" />
                </div>
            </div>

            <div class="mb-3">
                <label class="auth-label">Correo electrónico *</label>
                <div class="auth-input-group">
                    <i class="bi bi-envelope auth-input-icon"></i>
                    <input class="auth-input" type="email" @bind="_regEmail" @bind:event="oninput" placeholder="correo@ejemplo.com" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="auth-label">Contraseña *</label>
                    <div class="auth-input-group">
                        <i class="bi bi-lock auth-input-icon"></i>
                        <input class="auth-input" type="password" @bind="_regPass" @bind:event="oninput" placeholder="Mín. 8 car., 1 mayúscula, 1 número" />
                    </div>
                </div>
                <div class="col-6">
                    <label class="auth-label">Teléfono</label>
                    <div class="auth-input-group">
                        <i class="bi bi-phone auth-input-icon"></i>
                        <input class="auth-input" @bind="_regTel" @bind:event="oninput" placeholder="7000-0000" />
                    </div>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label class="auth-label">DUI</label>
                    <div class="auth-input-group">
                        <i class="bi bi-card-text auth-input-icon"></i>
                        <input class="auth-input" @bind="_regDui" @bind:event="oninput" placeholder="00000000-0" />
                    </div>
                </div>
                <div class="col-6">
                    <label class="auth-label">Nombre del hogar *</label>
                    <div class="auth-input-group">
                        <i class="bi bi-house auth-input-icon"></i>
                        <input class="auth-input" @bind="_regHogar" @bind:event="oninput" placeholder="Familia García" />
                    </div>
                </div>
            </div>

            <button class="auth-btn-secondary" @onclick="DoRegister" disabled="@_loading">
                @if (_loading)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Creando cuenta...</span>
                }
                else
                {
                    <i class="bi bi-person-plus me-2"></i>
                    <span>Crear cuenta</span>
                }
            </button>
        }

        <div class="auth-badge mt-4">
            🇸🇻 &nbsp;Hecho para El Salvador &nbsp;·&nbsp; USD &amp; Bitcoin
        </div>

    </div>
</div>

@code {
    string _tab = "login";
    string _email = "", _pass = "", _error = "";
    string _regNombre = "", _regEmail = "", _regPass = "", _regTel = "", _regDui = "", _regHogar = "";
    bool _loading;

    async Task LoginAdmin()   => await QuickLogin("admin@financehogar.com",   "Admin1234!");
    async Task LoginUsuario() => await QuickLogin("usuario@financehogar.com", "User1234!");

    async Task QuickLogin(string email, string pass)
    {
        _email = email; _pass = pass;
        await DoLogin();
    }

    async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_pass))
        { _error = "Correo y contraseña son requeridos"; return; }
        _loading = true; _error = "";
        var (ok, err) = await AuthSvc.LoginAsync(_email, _pass);
        _loading = false;
        if (ok) Nav.NavigateTo("/", forceLoad: false);
        else _error = err ?? "Error de autenticación";
    }

    async Task DoRegister()
    {
        if (string.IsNullOrWhiteSpace(_regNombre) || string.IsNullOrWhiteSpace(_regEmail) ||
            string.IsNullOrWhiteSpace(_regPass)   || string.IsNullOrWhiteSpace(_regHogar))
        { _error = "Los campos marcados con * son requeridos"; return; }
        _loading = true; _error = "";
        var req = new RegisterRequest(
            NombreCompleto: _regNombre,
            Email:          _regEmail,
            Password:       _regPass,
            Telefono:       string.IsNullOrWhiteSpace(_regTel) ? null : _regTel,
            Dui:            string.IsNullOrWhiteSpace(_regDui) ? null : _regDui,
            NombreHogar:    _regHogar);
        var (ok, err) = await AuthSvc.RegisterAsync(req);
        _loading = false;
        if (ok) Nav.NavigateTo("/", forceLoad: false);
        else _error = err ?? "Error en el registro";
    }
}
