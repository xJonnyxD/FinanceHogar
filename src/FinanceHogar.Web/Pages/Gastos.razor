@page "/gastos"
@attribute [Authorize]
@inject ApiService Api
@inject AuthService AuthSvc
@inject ToastService Toast

<PageTitle>Gastos — FinanceHogar</PageTitle>
<PageHeader Title="Gastos" Icon="bi-arrow-up-circle" ButtonLabel="Nuevo Gasto" OnButtonClick="OpenCreate" />

@if (_loading)
{ <div class="text-center py-4"><div class="spinner-border text-primary"></div></div> }
else if (!_items.Any())
{ <EmptyState Icon="bi-receipt" Message="No hay gastos registrados" ButtonLabel="Registrar primer gasto" OnButtonClick="OpenCreate" /> }
else
{
    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr><th>Fecha</th><th>Descripción</th><th>Categoría</th><th>Tipo</th><th>Monto</th><th>Moneda</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var g in _items)
                    {
                        <tr>
                            <td>@g.FechaGasto.ToString("dd/MM/yyyy")</td>
                            <td>@(g.Descripcion ?? "—")</td>
                            <td><span class="badge bg-danger bg-opacity-10 text-danger">@g.NombreCategoria</span></td>
                            <td>@g.Tipo</td>
                            <td class="fw-semibold text-danger">@Fmt(g.Monto)</td>
                            <td>@g.Moneda</td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" @onclick="()=>Remove(g.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<ModalWrapper Visible="_showModal" Title="@(_isEdit?"✏️ Editar Gasto":"➕ Nuevo Gasto")"
             OnClose="CloseModal" OnSave="Save" Saving="_saving">
    <div class="row g-3">
        <div class="col-12">
            <label class="form-label fw-semibold">Categoría *</label>
            <select class="form-select" @bind="_form.CategoriaId">
                <option value="@Guid.Empty">Seleccionar...</option>
                @foreach (var c in _categorias)
                { <option value="@c.Id">@c.Nombre</option> }
            </select>
        </div>
        <div class="col-6">
            <label class="form-label fw-semibold">Monto *</label>
            <div class="input-group">
                <span class="input-group-text">$</span>
                <input class="form-control" type="number" step="any" min="0" @bind="_form.Monto" />
            </div>
        </div>
        <div class="col-6">
            <label class="form-label fw-semibold">Moneda</label>
            <select class="form-select" @bind="_form.Moneda">
                <option value="1">USD</option>
                <option value="2">BTC (Bitcoin)</option>
            </select>
        </div>
        <div class="col-6">
            <label class="form-label fw-semibold">Tipo de gasto</label>
            <select class="form-select" @bind="_form.Tipo">
                <option value="1">Servicio Básico</option>
                <option value="2">Alimentación</option>
                <option value="3">Educación</option>
                <option value="4">Salud</option>
                <option value="5">Transporte</option>
                <option value="6">Entretenimiento</option>
                <option value="7">Ahorro</option>
                <option value="8">Cuota Tanda</option>
                <option value="9">Otro</option>
            </select>
        </div>
        <div class="col-6">
            <label class="form-label fw-semibold">Fecha *</label>
            <input class="form-control" type="date" @bind="_form.FechaGasto" />
        </div>
        <div class="col-12">
            <label class="form-label fw-semibold">Descripción</label>
            <input class="form-control" @bind="_form.Descripcion" placeholder="Opcional" />
        </div>
        <div class="col-6">
            <div class="form-check mt-2">
                <input class="form-check-input" type="checkbox" @bind="_form.EsRecurrente" id="chkRec" />
                <label class="form-check-label" for="chkRec">Es recurrente</label>
            </div>
        </div>
        @if (_form.EsRecurrente)
        {
            <div class="col-6">
                <label class="form-label fw-semibold">Frecuencia</label>
                <select class="form-select" @bind="_form.Frecuencia">
                    <option value="1">Diaria</option>
                    <option value="2">Semanal</option>
                    <option value="3">Mensual</option>
                    <option value="4">Trimestral</option>
                    <option value="5">Semestral</option>
                    <option value="6">Anual</option>
                </select>
            </div>
        }
    </div>
</ModalWrapper>

@code {
    bool _loading = true, _showModal, _isEdit, _saving;
    List<GastoDto> _items = [];
    List<CategoriaDto> _categorias = [];
    CreateGastoRequest _form = new();
    Guid _hogarId;

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthSvc.GetSessionAsync();
        if (session is null) return;
        _hogarId = session.HogarId;
        await Load();
    }

    async Task Load()
    {
        _loading = true;
        try
        {
            var (gastos, cats) = (await Api.GetGastosAsync(_hogarId), await Api.GetCategoriasAsync(_hogarId));
            _items = gastos ?? [];
            _categorias = (cats ?? []).Where(c => !c.EsIngreso).ToList();
        }
        catch (Exception e) { Toast.Error(e.Message); }
        finally { _loading = false; }
    }

    void OpenCreate()
    {
        _form = new CreateGastoRequest { HogarId = _hogarId, FechaGasto = DateOnly.FromDateTime(DateTime.Today) };
        _isEdit = false; _showModal = true;
    }

    void CloseModal() => _showModal = false;

    async Task Save()
    {
        if (_form.CategoriaId == Guid.Empty) { Toast.Error("Selecciona una categoría"); return; }
        if (_form.Monto <= 0) { Toast.Error("Ingresa un monto válido mayor a 0"); return; }
        _saving = true;
        try
        {
            await Api.CreateGastoAsync(_form);
            Toast.Success("Gasto registrado ✓");
            _showModal = false;
            await Load();
        }
        catch (Exception e) { Toast.Error(e.Message); }
        finally { _saving = false; }
    }

    async Task Remove(Guid id)
    {
        if (!await ConfirmDelete()) return;
        try { await Api.DeleteGastoAsync(id); Toast.Success("Gasto eliminado"); await Load(); }
        catch (Exception e) { Toast.Error(e.Message); }
    }

    // Simple JS confirm via JSInterop is not available here, use inline approach
    Task<bool> ConfirmDelete() => Task.FromResult(true); // simplificado

    string Fmt(decimal v) => "$" + v.ToString("N2");
}
